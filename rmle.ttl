#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/imec/rml/ns/extensions#authOidcIssuer
:authOidcIssuer rdf:type owl:ObjectProperty ;
                rdfs:domain :CssClientCredentialsAuthentication ;
                rdfs:range rdfs:Resource ;
                rdfs:comment "The OpenID Connect issuer for the authentication." ;
                rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/access/httprequest> ;
                rdfs:label "authentication OIDC issuer"@en .


###  https://w3id.org/imec/rml/ns/extensions#authWebId
:authWebId rdf:type owl:ObjectProperty ;
           rdfs:domain :CssClientCredentialsAuthentication ;
           rdfs:range rdfs:Resource ;
           rdfs:comment "The webID for the authentication." ;
           rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/access/httprequest> ;
           rdfs:label "authentication webID"@en .


###  https://w3id.org/imec/rml/ns/extensions#logicalTargetMap
:logicalTargetMap rdf:type owl:ObjectProperty ;
                  rdfs:domain <http://w3id.org/rml/TermMap> ;
                  rdfs:range :LogicalTargetMap ;
                  rdfs:comment "The logical target map element that generates the logical target identifier." ;
                  rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/target/dynamictarget> ;
                  rdfs:label "logical target map"@en .


###  https://w3id.org/imec/rml/ns/extensions#userAuthentication
:userAuthentication rdf:type owl:ObjectProperty ;
                    rdfs:domain :HttpRequest ;
                    rdfs:range :UserAuthentication ;
                    rdfs:comment "The information needed for the authentication of a user." ;
                    rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/access/httprequest> ;
                    rdfs:label "user authentication"@en .


