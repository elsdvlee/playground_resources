#    Data properties
#################################################################

###  https://w3id.org/imec/rml/ns/extensions#acceptHeader
:acceptHeader rdf:type owl:DatatypeProperty ;
              rdfs:domain :HttpRequest ;
              rdfs:range xsd:string ;
              rdfs:comment "The value for the Accept header." ;
              rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/access/httprequest> ;
              rdfs:label "accept header"@en .


###  https://w3id.org/imec/rml/ns/extensions#authEmail
:authEmail rdf:type owl:DatatypeProperty ;
           rdfs:domain :CssClientCredentialsAuthentication ;
           rdfs:range xsd:string ;
           rdfs:comment "The email for the authentication." ;
           rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/access/httprequest> ;
           rdfs:label "authentication email"@en .


###  https://w3id.org/imec/rml/ns/extensions#authPassword
:authPassword rdf:type owl:DatatypeProperty ;
              rdfs:domain :CssClientCredentialsAuthentication ;
              rdfs:range xsd:string ;
              rdfs:comment "The password for the authentication." ;
              rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/access/httprequest> ;
              rdfs:label "authentication password"@en .


###  https://w3id.org/imec/rml/ns/extensions#contentTypeHeader
:contentTypeHeader rdf:type owl:DatatypeProperty ;
                   rdfs:domain :HttpRequest ;
                   rdfs:range xsd:string ;
                   rdfs:comment "The value for the Content-Type header." ;
                   rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/access/httprequest> ;
                   rdfs:label "content-type header"@en .


###  https://w3id.org/imec/rml/ns/extensions#linkRelation
:linkRelation rdf:type owl:DatatypeProperty ;
              rdfs:domain :LinkedHttpRequest ;
              rdfs:range xsd:string ;
              rdfs:comment "The relation in the Link header." ;
              rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/access/httprequest> ;
              rdfs:label "link relation"@en .


###  https://w3id.org/imec/rml/ns/extensions#linkingAbsoluteURI
:linkingAbsoluteURI rdf:type owl:DatatypeProperty ;
                    rdfs:domain :LinkedHttpRequest ;
                    rdfs:range xsd:string ;
                    rdfs:comment "The absolute URI of the linking web resource." ;
                    rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/access/httprequest> ;
                    rdfs:label "linking absolute URI"@en .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/2000/01/rdf-schema#Resource
rdfs:Resource rdf:type owl:Class .


###  https://w3id.org/imec/rml/ns/extensions#CssClientCredentialsAuthentication
:CssClientCredentialsAuthentication rdf:type owl:Class ;
                                    rdfs:subClassOf :UserAuthentication ;
                                    rdfs:comment "Represents a resource holding information needed for authentication using client credentials on the Solid Community Server." ;
                                    rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/access/httprequest> ;
                                    rdfs:label "CSS Client Credentials Authentication Info"@en .


###  https://w3id.org/imec/rml/ns/extensions#DirectHttpRequest
:DirectHttpRequest rdf:type owl:Class ;
                   rdfs:subClassOf :HttpRequest ;
                   rdfs:comment "Represents a direct HTTP request access description." ;
                   rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/access/httprequest> ;
                   rdfs:label "Direct HTTP Request"@en .


###  https://w3id.org/imec/rml/ns/extensions#HttpRequest
:HttpRequest rdf:type owl:Class ;
             rdfs:subClassOf <https://www.w3.org/TR/HTTP-in-RDF10/HttpRequest> ;
             rdfs:comment "Represents an abstract HTTP request access description." ;
             rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/access/httprequest> ;
             rdfs:label "HTTP Request"@en .


###  https://w3id.org/imec/rml/ns/extensions#LinkedHttpRequest
:LinkedHttpRequest rdf:type owl:Class ;
                   rdfs:subClassOf :HttpRequest ;
                   rdfs:comment "Represents a linked HTTP request access description." ;
                   rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/access/httprequest> ;
                   rdfs:label "Linked HTTP Request"@en .


###  https://w3id.org/imec/rml/ns/extensions#LogicalTargetMap
:LogicalTargetMap rdf:type owl:Class ;
                  rdfs:subClassOf <http://w3id.org/rml/ExpressionMap> ;
                  rdfs:comment "Represents a logical target map." ;
                  rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/target/dynamictarget> ;
                  rdfs:label "Logical Target Map"@en .


###  https://w3id.org/imec/rml/ns/extensions#UserAuthentication
:UserAuthentication rdf:type owl:Class ;
                    rdfs:comment "Represents a resource holding information needed for user authentication." ;
                    rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/access/httprequest> ;
                    rdfs:label "Authentication Info"@en .


###  https://www.w3.org/TR/HTTP-in-RDF10/HttpRequest
<https://www.w3.org/TR/HTTP-in-RDF10/HttpRequest> rdf:type owl:Class .


