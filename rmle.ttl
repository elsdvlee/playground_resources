#    Individuals
#################################################################

###  https://w3id.org/imec/rml/ns/extensions#ThisMapping
:ThisMapping rdf:type owl:NamedIndividual ,
                      <http://w3id.org/rml/LogicalTarget> ;
             rdfs:comment "Represents a logical target that adds the RDF triples to the mapping used for their generation." ;
             rdfs:isDefinedBy <https://w3id.org/imec/rml/specs/target/dynamictarget> ;
             rdfs:label "This Mapping"@en .


